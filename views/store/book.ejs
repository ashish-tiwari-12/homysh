<%- include('../partials/head') %>

  <body>
    <%- include('../partials/nav') %>

      <main class="container mx-auto p-8 max-w-2xl">
        <h2 class="text-3xl font-bold text-gray-800 mb-6">
          Book Your Stay at <span class="text-red-500">
            <%= home.houseName %>
          </span>
        </h2>

        <!-- Flash Messages -->
        <% if (success_msg && success_msg.length> 0) { %>
          <div class="mb-4 p-3 rounded bg-green-100 text-green-800 font-semibold">
            <%= success_msg[0] %>
          </div>
          <% } %>

            <% if (error_msg && error_msg.length> 0) { %>
              <div class="mb-4 p-3 rounded bg-red-100 text-red-800 font-semibold">
                <%= error_msg[0] %>
              </div>
              <% } %>


                <form action="/book/<%= home._id %>" method="POST" class="bg-white p-6 rounded-lg shadow-md space-y-6">

                  <!-- Check-In -->
                  <div>
                    <label for="checkIn" class="block text-sm font-medium text-gray-700 mb-1">Check-In Date</label>
                    <input type="date" id="checkIn" name="checkIn" required
                      class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-red-400">
                  </div>

                  <!-- Check-Out -->
                  <div>
                    <label for="checkOut" class="block text-sm font-medium text-gray-700 mb-1">Check-Out Date</label>
                    <input type="date" id="checkOut" name="checkOut" required
                      class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-red-400">
                  </div>

                  <!-- Number of People -->
                  <div>
                    <label for="guests" class="block text-sm font-medium text-gray-700 mb-1">Number of People</label>
                    <input type="number" id="guests" name="guests" min="1" max="20" required
                      class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-red-400">
                  </div>

                  <!-- Submit Button -->
                  <button type="submit"
                    class="w-full bg-red-500 text-white font-semibold py-2 rounded-md hover:bg-red-600 transition duration-300">
                    Confirm Booking
                  </button>
                </form>
      </main>

      <script>
        // Disable past dates
        const today = new Date().toISOString().split('T')[0]; // YYYY-MM-DD
        const checkIn = document.getElementById('checkIn');
        const checkOut = document.getElementById('checkOut');

        checkIn.setAttribute('min', today);
        checkOut.setAttribute('min', today);

        // Auto-update checkout min date based on selected check-in
        checkIn.addEventListener('change', () => {
          if (checkIn.value) {
            checkOut.min = checkIn.value;
            if (checkOut.value < checkIn.value) {
              checkOut.value = checkIn.value;
            }
          }
        });
      </script>
  </body>

  </html>