<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-gray-100">
  <%- include('../partials/nav') %>

  <main class="container mx-auto mt-16 p-8 bg-white rounded-lg shadow-md max-w-lg">
    <div class="text-center mb-6 border-b pb-4">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-50 text-red-500 mb-4">
        <i class="fas fa-key text-2xl"></i>
      </div>
      <h1 class="text-3xl font-bold text-gray-800">Forgot Password</h1>
      <p class="text-gray-500 mt-2">Enter your email and we'll send you an OTP to reset your password.</p>
    </div>

    <form action="/forgot-password" method="POST" class="max-w-md mx-auto">
      
      <% if (error) { %>
        <div class="mb-4 p-3 rounded bg-red-100 text-red-800 font-semibold text-sm">
          <%= error %>
        </div>
      <% } %>
      
      <% if (success) { %>
        <div class="mb-4 p-3 rounded bg-green-100 text-green-800 font-semibold text-sm">
          <%= success %>
        </div>
      <% } %>

      <div class="mb-6">
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
            <i class="fas fa-envelope"></i>
          </span>
          <input type="email" id="email" name="email" placeholder="your.email@example.com"
            class="w-full pl-10 px-4 py-3 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 transition"
            required />
        </div>
      </div>

      <button type="submit"
        class="w-full bg-red-500 text-white py-3 rounded-md hover:bg-red-600 focus:ring-4 focus:ring-red-300 font-medium transition duration-300 flex items-center justify-center">
        <span>Send OTP</span>
        <i class="fas fa-paper-plane ml-2"></i>
      </button>

      <p class="text-center mt-6 text-gray-600 text-sm">
        Remembered your password? <a href="/login" class="text-red-500 hover:underline font-medium">Log in</a>
      </p>
    </form>
  </main>
</body>
</html>
